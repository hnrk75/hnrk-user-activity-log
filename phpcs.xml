<?xml version="1.0"?>
<ruleset name="HNRK User Activity Log">
    <description>WordPress Coding Standards for HNRK User Activity Log</description>

    <rule ref="WordPress"/>

    <!-- Scan these files -->
    <file>.</file>

    <!-- Ignore these folders -->
    <exclude-pattern>vendor/</exclude-pattern>
    <exclude-pattern>node_modules/</exclude-pattern>

    <!-- Only scan PHP files -->
    <arg name="extensions" value="php"/>
</ruleset>
